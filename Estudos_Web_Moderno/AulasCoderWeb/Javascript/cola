// --- 1.2 O Perigo do 'undefined' e o 'return' ---
// Map, Filter e Reduce dependem do que você retorna. Se esquecer o 'return' dentro de chaves {}, o resultado vira 'undefined' e quebra o próximo método.
const listaQuebrada = [1, 2].map(n => { n * 2 }); // Retorna [undefined, undefined]
const listaCerta = [1, 2].map(n => { return n * 2 }); // Retorna [2, 4]

// --- 1.3 Contexto Léxico (Escopo) ---
// O JS procura variáveis de dentro para fora.
const global = 'sou global';
function minhaFuncao() {
    const local = 'sou local';
    // Consegue ver 'global' e 'local'
    console.log(global, local);
}
//console.log(local); // ERRO! Não consegue ver 'local' aqui fora.

