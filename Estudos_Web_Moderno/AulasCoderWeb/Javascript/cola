// --- 5.1 Object.entries() - O Portal Objeto -> Array ---
// Transforma objeto "duro" em uma lista de pares [chave, valor]. Essencial para processar objetos com Map.
const notas = { Allan: 10, Bia: 8 };
const listaNotas = Object.entries(notas); // [ ["Allan", 10], ["Bia", 8] ]
listaNotas.map(([aluno, nota]) => `O aluno ${aluno} tirou ${nota}`);

// Outras funções de Objeto: keys (pega as chaves), values (pega os valores), assign (copia objetos).

// --- 5.2 Getters e Setters (Acessadores) ---
// Permite controlar o acesso a uma propriedade como se fosse uma função.
const objGetSet = {
    _valor: 0, // Convenção para propriedade "privada"
    get valor() { return this._valor; },
    set valor(novo) { if(novo > 0) this._valor = novo; } // Filtra o que entra
};
objGetSet.valor = 10; // Chama o setter automaticamente
console.log(objGetSet.valor); // Chama o getter automaticamente (imprime 10)

// --- 5.3 Classes e Herança (Sintaxe OO) ---
class Animal {
    constructor(nome) { this.nome = nome; }
    falar() { return `${this.nome} faz barulho.`; }
}

class Cachorro extends Animal { // Herança
    falar() { // Polimorfismo: reescreve o método do pai
        // super.falar() // Opcional: Chama o método do pai antes
        return `${this.nome} latiu.`; 
    }
}
const bob = new Cachorro("Bob");
console.log(bob.falar()); // "Bob latiu."

// --- 5.4 Evitando Modificações ---
const objTravado = { a: 1 };
Object.freeze(objTravado); // Trava completamente: não adiciona, não remove, não edita.
// Object.seal(objTravado); // Seal: impede adicionar/remover, mas permite editar valores existentes.
objTravado.a = 2; // Ignorado
console.log(objTravado.a); // Imprime 1

