// --- 2.1 Condicionais (if/else, switch) ---
if (nota >= 7) {
    // Aprovado
} else if (nota >= 5) {
    // Recuperação
} else {
    // Reprovado
}

// Switch: Bom para muitas opções fixas
const opcao = 'A';
switch (opcao) {
    case 'A': console.log("Opção A"); break; // 'break' é obrigatório!
    case 'B': console.log("Opção B"); break;
    default: console.log("Opção Inválida");
}

// --- 2.2 Loops Tradicionais (while, do-while, for) ---
// While: Use quando não sabe quantas vezes vai rodar
let c = 0;
while (c < 5) {
    console.log(c);
    c++;
}

// For: Use quando sabe o limite exato
for (let i = 0; i < 5; i++) {
    console.log(i);
}

// --- 2.3 Loops Modernos (for-in, for-of) ---
const frutas = ['Maçã', 'Uva'];
const pessoa = { nome: 'Allan', idade: 25 };

for (let indice in frutas) { console.log(indice); } // 'for-in' pega ÍNDICES/CHAVES (0, 1)
for (let fruta of frutas) { console.log(fruta); } // 'for-of' pega VALORES (Maçã, Uva) - Ótimo para Arrays

for (let chave in pessoa) { console.log(chave, pessoa[chave]); } // 'for-in' pega chaves de OBJETOS (nome, idade)

// --- 2.4 Controle de Loops (break, continue) ---
for (let i = 0; i < 10; i++) {
    if (i === 5) continue; // Pula o resto desta iteração (pula o 5)
    if (i === 8) break;    // Para o loop inteiro imediatamente (para antes do 8)
    console.log(i); // Imprime 0,1,2,3,4,6,7
}

// #endregion


