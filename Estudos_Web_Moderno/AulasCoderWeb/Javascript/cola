// #region CATEGORIA 4: MANIPULAÇÃO DE ARRAYS MODERNOS (A Trindade + Destructuring)
// Fonte: Todo o nosso treinamento prático no chat.
// ==============================================================================

const dadosBrutos = [
    { id: 1, item: "PC", preco: 3000, qtd: 2 },
    { id: 2, item: "Mouse", preco: 100, qtd: 0 },
    { id: 3, item: "Monitor", preco: 1500, qtd: 1 },
];

// --- 4.1 O Pipeline Perfeito (Encadeamento) ---
// Objetivo: Saber o valor total de estoque de produtos disponíveis, com 10% de desconto.
const faturamentoTotal = dadosBrutos
    // 1. FILTER + Destructuring de Objeto: Só deixa passar quem tem qtd > 0
    .filter(({ qtd }) => qtd > 0)
    
    // 2. MAP + Destructuring de Objeto: Cria uma nova lista apenas com os valores totais já com desconto
    .map(({ preco, qtd }) => preco * qtd * 0.9)
    
    // 3. REDUCE: Soma tudo em um único número final
    .reduce((acumulador, precoComDesconto) => acumulador + precoComDesconto, 0);

console.log(`Faturamento: R$ ${faturamentoTotal}`); // R$ 6210 (5400 + 0 + 1350)

// --- 4.2 Destructuring Cheat Sheet ---
const arrEx = ["Allan", 25, "SP"];
const objEx = { nome: "Bia", idade: 22 };

// Em Array, a ordem importa:
const [nomeArr, idadeArr] = arrEx; // nomeArr="Allan", idadeArr=25

// Em Objeto, o nome da chave importa:
const { nome, idade } = objEx; // nome="Bia", idade=22

