// --- 3.1 Formas de Declaração ---
function tradicional() { return 'sou tradicional'; } // Sofre Hoisting (pode ser usada antes de declarar)
const expression = function() { return 'sou expressão'; }; // Não sofre hoisting

// --- 3.2 Arrow Function (Sintaxe Moderna) ---
// Quando usar: Para códigos curtos e para travar o valor do 'this'.
const arrow = (a, b) => a + b; // Retorno implícito (sem chaves)
const arrowLonga = (a, b) => {
    // Com chaves, precisa do return!
    return a + b;
};

// --- 3.3 O Mistério do 'this' e '.bind()' ---
// O 'this' muda dependendo de QUEM chama a função.
const carro = {
    velocidade: 90,
    getVelocidade: function() { return this.velocidade; }
};
const velocidadeSolta = carro.getVelocidade;
// console.log(velocidadeSolta()); // undefined! 'this' agora é o contexto global (window/node)

// .bind(): "Cola" um 'this' específico na função para sempre
const velocidadeColada = carro.getVelocidade.bind(carro);
console.log(velocidadeColada()); // 90. Bind travou o 'this' no objeto 'carro'.

// --- 3.4 Callbacks ---
// Passar uma função como argumento para outra função. Essencial para Map/Filter/Reduce.
const somar = (a, b) => a + b;
const calcular = (x, y, funcaoCallback) => funcaoCallback(x, y);
console.log(calcular(10, 5, somar)); // 15

// --- 3.5 Parâmetros Padrão e Variáveis (Rest) ---
const saudacao = (nome = 'Visitante') => `Olá ${nome}`; // Default

// Rest Parameter (...): Pega muitos argumentos soltos e junta num Array
const somarTudo = (...numeros) => numeros.reduce((t, n) => t + n, 0);
console.log(somarTudo(1, 2, 3, 4, 5)); // 15

// --- 3.6 Closures e IIFE ---
// IIFE (Immediately Invoked Function Expression): Roda imediatamente e cria escopo privado
(function() {
    const segredo = "ninguém vê";
})();
// console.log(segredo); // Erro de acesso

// Closure: A função "lembra" do escopo onde foi criada
function criaContador() {
    let count = 0;
    return function() { return count++; }; // Lembra de 'count'
}
const contador = criaContador();
// contador(); // 0, contador(); // 1...

